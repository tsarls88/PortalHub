@model IEnumerable<PortalHub.Models.PortalhubModel>

<div class="container py-4">
    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            @foreach (var app in Model)
            {
                <div class="col-md-4 col-sm-6">
                    <div class="card h-100 shadow-sm hover-shadow transition" style="cursor: pointer;"
                         onclick="window.open('@app.AppUrl', '_blank')">
                        <div class="card-body text-center p-4">
                            <div class="mb-3">
                                <i class="bi @(string.IsNullOrEmpty(app.IconClass) ? "bi-app-indicator" : app.IconClass) text-primary"
                                   style="font-size: 3rem;"></i>
                            </div>
                            <h4 class="card-title fw-bold">@app.AppName</h4>
                            <p class="card-text text-muted">@(app.Description ?? "No description available.")</p>
                        </div>
                        <div class="card-footer bg-transparent border-0 pb-4 text-center">
                            <span class="btn btn-outline-primary rounded-pill px-4">Launch App</span>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <div class="alert alert-warning border-0 shadow-sm p-5">
                    <i class="bi bi-search text-muted mb-3" style="font-size: 4rem;"></i>
                    <h3 class="fw-light">No Applications Found</h3>
                    <p class="text-secondary">We couldn't find any active systems in the database. Please check your connection or filters.</p>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .transition {
        transition: all 0.3s ease;
    }

    .hover-shadow:hover {
        transform: translateY(-5px);
        box-shadow: 0 1rem 3rem rgba(0,0,0,.175) !important;
    }
</style>