@model IEnumerable<PortalHub.Models.PortalhubModel>



@{
    ViewData["Title"] = "Application Hub";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">Service Portal</h1>
        <p class="lead text-muted">Select an application below to get started.</p>
    </div>

    <div class="row g-4">
        @foreach (var app in Model)
        {
            <div class="col-md-4 col-sm-6">
                <div class="card h-100 shadow-sm app-card" onclick="window.open('@app.AppUrl', '_blank')">
                    <div class="card-body text-center p-4">
                        <div class="mb-3">
                            <i class="bi @app.IconClass" style="font-size: 3.5rem; color: #0d6efd;"></i>
                        </div>
                        <h4 class="card-title fw-bold">@app.AppName</h4>

                        <p class="card-text text-secondary">@app.Description</p>
                    </div>
                    <div class="card-footer bg-transparent border-0 pb-4 text-center">
                        <span class="btn btn-outline-primary rounded-pill px-4">
                            Launch App <i class="bi bi-box-arrow-up-right ms-2"></i>
                        </span>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
